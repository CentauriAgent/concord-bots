# =============================================================================
# bot.toml.example — Bot configuration template
# =============================================================================
#
# Copy this file to config/bot.toml and edit for your bot.
# Or set BOT_CONFIG=/path/to/bot.toml to use a custom path.
#
# Every field is optional. With no config, the bot auto-generates an identity
# and requires manual invite acceptance.

[bot]
# The bot's Nostr private key (nsec).
# Options:
#   nsec = "nsec1..."   — use this specific key
#   nsec = "auto"        — auto-generate on first run (default)
#   # (omit)            — falls back to NSEC environment variable
nsec = "auto"

# Who can invite this bot to communities?
#   "owner"      — ONLY the auth.owner npub can invite (default)
#   "authorized"  — auth.owner + all auth.authorized npubs can invite
#   "public"     — accept invites from anyone
#   "whitelist"  — (legacy) only npubs in bot.whitelist below
#   "manual"     — park all invites, require explicit acceptance
invite_policy = "owner"

# Only used when invite_policy = "whitelist" (legacy)
# whitelist = [
#   "npub1abcdef...",
#   "npub1ghijkl...",
# ]

# Bot profile (optional — shown to users in Vector, published as kind 0 to relays on startup)
# display_name = "Keystone"
# A short description shown on the bot's Nostr profile.
# about = "A Concord Protocol bot built with concord-bots"
# picture = "https://example.com/avatar.png"
# banner = "https://example.com/banner.png"
# lud16 = "<bot-npub>@npub.cash"  # Lightning address — enables receiving zaps

# =============================================================================
# Authorization — owner and permission system
# =============================================================================
#
# When configured, enables built-in auth commands (!add, !remove, !list, !auth)
# and lets you gate custom commands by permission level.
# When not configured, all commands are public (backward-compatible).

[auth]
# Bot owner's npub (required to enable auth system).
# The owner has full control: can !add/!remove users, run Owner-only commands.
# owner = "npub1yournpub..."

# Initial authorized npubs (seed list).
# Additional users can be added at runtime via !add.
# authorized = [
#   "npub1friend1...",
#   "npub1friend2...",
# ]

# Persist the authorized list across restarts (default: true).
# persist = true

# State file for the authorized list (default: "auth_state.json").
# state_file = "auth_state.json"

# =============================================================================
# Communities — channels to join on startup
# =============================================================================

[communities]
# List of community IDs to join when the bot starts.
# You can find community IDs in Vector's UI or via the API.
# join = [
#   "community-id-1",
#   "community-id-2",
# ]

# =============================================================================
# Scheduling — default settings for scheduled tasks
# =============================================================================

[scheduling]
# Default interval (seconds) for scheduled tasks that don't specify their own.
# default_interval_secs = 300

# =============================================================================
# Wallet — Cashu ecash wallet for tips, deposits, and Lightning payments
# =============================================================================

[wallet]
# Enable the built-in Cashu wallet (default: false).
# When enabled, the bot can receive Lightning payments and send Cashu tokens.
# Commands: !balance, !tip <sats>, !deposit [sats], !withdraw <invoice>
# enabled = false

# Mint URL for the Cashu mint (default: minibits).
# Other popular mints:
#   "https://8333.space:3338" (bitcoin space)
#   "https://stablenut.umint.cash" (test mint)
# mint_url = "https://mint.minibits.cash/Bitcoin"

# =============================================================================
# npub.cash — receive Lightning zaps as Cashu tokens
# =============================================================================
#
# When someone zaps <bot-npub>@npub.cash, npub.cash mints Cashu tokens
# and holds them. The bot periodically claims them via NIP-98 auth
# (signed kind 27235 Nostr event) and receives them into its Cashu wallet.
#
# Requires lud16 to be set in [bot] section pointing to <bot-npub>@npub.cash.

[npub_cash]
# enabled = true
# url = "https://npub.cash"
# claim_interval_secs = 300  # poll every 5 minutes

# =============================================================================
# Custom — any additional config for your handlers
# =============================================================================

# Everything under [custom] is accessible via ctx.config.custom_get("key")
# and ctx.config.custom_string("key") in your handlers.

# Example: GitHub integration
# [custom.github]
# repo = "your-org/your-repo"
# token = "ghp_..."

# Example: AI integration (enables AI responses to non-command messages)
# [custom.ai]
# enabled = true
# provider = "openclaw"          # or "openai"
# model = "gpt-4o-mini"          # only used for OpenAI
# system_prompt = "You are a helpful Vector community bot."
# api_key = "sk-..."             # or set AI_API_KEY env var

# =============================================================================
# Features — toggle command groups
# =============================================================================
#
# All feature flags default to true except `ai`. When a feature is disabled,
# the corresponding commands are silently ignored.
#
# [features]
# utility = true        # !price, !time, !roll, !weather, !remind, !poll, etc.
# fun = true            # !8ball, !flip, !choose, !rps
# community = true      # !level, !leaderboard, !profile, !giveaway, !rep
# nostr = true          # !nostr, !nip05, !follow, !balance, !tip, !zap, !deposit
# moderation = true     # !kick, !ban, !unban, !warn, !grantmod, !revokemod
# git_monitor = true    # !git add/remove/list/poll
# ai = false            # AI-powered responses to non-command messages
# thread_replies = true # Send command responses as kind 1111 threaded replies (CORD-03 §3)
#                        # When false, uses regular kind 9 inline replies
# leaderboard = true    # XP tracking, level-ups, !level/!rank/!leaderboard
#                        # Can also be toggled per-community with !leaderboard on|off
#                        # When false, uses regular kind 9 inline replies

# =============================================================================
# V2 Community Management — Concord v2 protocol features
# =============================================================================
#
# Controls automatic community creation and joining on startup.

# [v2]
# Automatically create a v2 community on startup if the bot isn't in any.
# auto_create = false

# Name for the auto-created community.
# community_name = "My Bot Community"

# Invite links to join on startup.
# join_on_start = [
#   "https://vector.app/invite/...",
# ]
